{
  "duration": 60,
  "speakers": {
    "ayumu": [
      {
        "start": 27.35,
        "end": 34.35,
        "text": "えっと今はなんで前回いたのはえっとツアーファイのヤオンやった時なんで"
      },
      {
        "start": 34.35,
        "end": 34.91,
        "text": "はいはいはい"
      },
      {
        "start": 34.91,
        "end": 36.83,
        "text": "5月11ですね"
      },
      {
        "start": 36.83,
        "end": 37.55,
        "text": "はいはい"
      },
      {
        "start": 37.55,
        "end": 42.21,
        "text": "で7月末に帰ってきたんで2ヶ月くらいは空いて"
      },
      {
        "start": 43.71,
        "end": 44.17,
        "text": "そうですね"
      }
    ],
    "skyhi": [
      {
        "start": 13.66,
        "end": 17.97,
        "text": "ココロッポンギからお届けしていますスカイハイガーナビゲートダイブトゥダニューワールド"
      },
      {
        "start": 17.97,
        "end": 20.23,
        "text": "今夜のゲストはあよむ今津さんですよろしくお願いします"
      },
      {
        "start": 20.23,
        "end": 21.07,
        "text": "よろしくお願いします"
      },
      {
        "start": 21.37,
        "end": 22.09,
        "text": "元気ですか?"
      },
      {
        "start": 22.25,
        "end": 23.01,
        "text": "元気ですよ"
      },
      {
        "start": 23.35,
        "end": 24.37,
        "text": "元気モリモリです"
      },
      {
        "start": 24.37,
        "end": 27.35,
        "text": "今はさどんくらいのペースなんですか日本アメリカは"
      },
      {
        "start": 42.21,
        "end": 43.07,
        "text": "なるほどね"
      },
      {
        "start": 44.65,
        "end": 50.79,
        "text": "なんかこうそういう意味だと日本での活動も盛んにどんどんなっていってるし"
      },
      {
        "start": 50.79,
        "end": 51.33,
        "text": "はい"
      },
      {
        "start": 51.33,
        "end": 53.79,
        "text": "アメリカでもライブもやったと"
      },
      {
        "start": 53.79,
        "end": 54.71,
        "text": "そうなんですよ"
      },
      {
        "start": 54.71,
        "end": 54.93,
        "text": "ね"
      },
      {
        "start": 54.93,
        "end": 55.37,
        "text": "はい"
      },
      {
        "start": 55.37,
        "end": 57.57,
        "text": "なんかどんな感じですか"
      },
      {
        "start": 57.57,
        "end": 59.37,
        "text": "いやーやばかったですよ"
      }
    ]
  },
  "annotations": [
    {
        "start": 1.01,
        "end": 4.96,
        "text": "チャレンジ アストゥースクセス"
      }
  ]
}